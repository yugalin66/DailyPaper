# Required
GEMINI_API_KEY=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_USER_ID=

# Gemini model fallback order. Model IDs are configurable because preview IDs change.
GEMINI_MODELS=gemini-3-flash-preview,gemini-3.5-flash,gemini-2.5-flash

# Metadata APIs
CONTACT_EMAIL=
IEEE_API_KEY=

# Runtime
PAPERBOT_TIMEZONE=Asia/Taipei
PAPERBOT_DB_PATH=data/paperbot.sqlite3
PAPERBOT_LOCK_PATH=data/paperbot.lock
PAPERBOT_MAX_CANDIDATES=20
PAPERBOT_MAX_PDF_MB=50
PAPERBOT_MAX_PAPER_CHARS=60000
PAPERBOT_VENUES=ISCA,MICRO,HPCA,ASPLOS
PAPERBOT_PREFERRED_KEYWORDS=GPU,GPGPU
PAPERBOT_LOG_LEVEL=INFO

